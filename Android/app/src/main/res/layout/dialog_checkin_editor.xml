<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="选择日期"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_dialog_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:text="2025-10-01"
        android:textSize="16sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="打卡状态"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/rg_dialog_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rb_in_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="进行中" />

        <RadioButton
            android:id="@+id/rb_interrupted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="中断" />

        <RadioButton
            android:id="@+id/rb_completed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:checked="true"
            android:text="完成" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="备注（心得/原因）"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_dialog_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="写点什么..."
        android:minLines="2" />

</LinearLayout>
