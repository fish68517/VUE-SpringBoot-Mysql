<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_stats_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="早起"
            android:textColor="#17121F"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_stats_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="连续打卡日历视图"
            android:textColor="#6B6276"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_stats_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="连续 5 天，累计完成 12 次"
            android:textColor="#4F378B"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_stats_completion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="最近 7 天完成 4 次"
            android:textColor="#17121F"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_stats_legend"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="绿色已完成，橙色进行中，红色中断，灰色无记录"
            android:textColor="#7B7386"
            android:textSize="12sp" />

        <GridLayout
            android:id="@+id/grid_habit_calendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:alignmentMode="alignMargins"
            android:columnCount="7"
            android:useDefaultMargins="true" />

        <TextView
            android:id="@+id/tv_stats_record_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="签到记录完成情况"
            android:textColor="#17121F"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_stats_record_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="2026-03-30 已完成"
            android:textColor="#6B6276"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
