<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HakimiPet" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_color</item>
    </style>
    
    <style name="Theme.HakimiPet.Launcher" parent="Theme.HakimiPet">
        <item name="android:windowBackground">@color/primary_color</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    
    <!-- 无ActionBar的主题变体，用于使用自定义Toolbar的Activity -->
    <style name="Theme.HakimiPet.NoActionBar" parent="Theme.HakimiPet">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>

