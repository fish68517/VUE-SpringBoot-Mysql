<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.admin.mapper.FitnessPlanMapper">

    <resultMap id="FitnessPlanResultMap" type="com.admin.entity.FitnessPlan">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="goal" property="goal"/>
        <result column="plan_content" property="planContent"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="findById" parameterType="Long" resultMap="FitnessPlanResultMap">
        SELECT id, user_id, goal, plan_content, created_at, updated_at
        FROM fitness_plans
        WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="FitnessPlanResultMap">
        SELECT id, user_id, goal, plan_content, created_at, updated_at
        FROM fitness_plans
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(*)
        FROM fitness_plans
    </select>

    <insert id="insert" parameterType="com.admin.entity.FitnessPlan" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO fitness_plans (user_id, goal, plan_content, created_at, updated_at)
        VALUES (#{userId}, #{goal}, #{planContent}, NOW(), NOW())
    </insert>

    <update id="update" parameterType="com.admin.entity.FitnessPlan">
        UPDATE fitness_plans
        <set>
            <if test="goal != null">goal = #{goal},</if>
            <if test="planContent != null">plan_content = #{planContent},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="Long">
        DELETE FROM fitness_plans
        WHERE id = #{id}
    </delete>

</mapper>
